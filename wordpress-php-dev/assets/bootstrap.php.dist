<?php
/**
 * PHPUnit Bootstrap File
 *
 * Loads Composer autoloader and sets up test environment.
 */

// Load Composer autoloader
require_once dirname( __DIR__ ) . '/vendor/autoload.php';

// Set up Brain Monkey for WordPress function mocking
\Brain\Monkey\setUp();

// Register a shutdown function to tear down Brain Monkey
register_shutdown_function( function() {
    \Brain\Monkey\tearDown();
} );

// Define WordPress constants for testing if needed
if ( ! defined( 'ABSPATH' ) ) {
    define( 'ABSPATH', '/tmp/wordpress/' );
}

if ( ! defined( 'WP_CONTENT_DIR' ) ) {
    define( 'WP_CONTENT_DIR', ABSPATH . 'wp-content' );
}

if ( ! defined( 'WP_PLUGIN_DIR' ) ) {
    define( 'WP_PLUGIN_DIR', WP_CONTENT_DIR . '/plugins' );
}
